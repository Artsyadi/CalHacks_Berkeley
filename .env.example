# ── PromptToPath environment ──────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.

# ASI:One agentic LLM (OpenAI-compatible).  https://asi1.ai  -> API key
# Underscore form preferred; the colon form (ASI:ONE_API_KEY) is also read.
ASI_ONE_API_KEY=sk_xxx

# Anthropic (optional) — used as the cross-model "Critic" persona in the debate.
ANTHROPIC_API_KEY=sk-ant-xxx

# Resource agent — real link sources
YOUTUBE_API_KEY=          # Google Cloud -> enable "YouTube Data API v3" -> API key (free)
TAVILY_API_KEY=           # https://tavily.com free tier (LLM-friendly web search)

# Agent seed phrases — unique random strings, NO spaces. Determine each agent's address.
ORCHESTRATOR_SEED=change-me-orchestrator-seed
PLANNER_SEED=change-me-planner-seed
RESOURCE_SEED=change-me-resource-seed
GRAPH_SEED=change-me-graph-seed

# Inter-agent addresses — fill in after first run (printed on startup / shown in Agent Inspector).
PLANNER_ADDRESS=
RESOURCE_ADDRESS=
GRAPH_ADDRESS=
ORCHESTRATOR_ADDRESS=

# Payment (sandboxed) — no real charge while PAYMENT_SANDBOX=true. Card details are never collected.
PAYMENT_SANDBOX=true
STRIPE_SECRET_KEY=         # test mode only (sk_test_...), unused while sandboxed
STRIPE_PUBLISHABLE_KEY=    # test mode only (pk_test_...), unused while sandboxed

# Ports (local)
ORCHESTRATOR_PORT=8001
PLANNER_PORT=8002
RESOURCE_PORT=8003
GRAPH_PORT=8004
